{
  "name": "limitly",
  "version": "2.0.0",
  "description": "Express-rate-limit, but distributed, Redis-powered, and production ready.",
  "author": "Arpan Das <dasarpan471@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/adasarpan404/limitly#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adasarpan404/limitly.git"
  },
  "bugs": {
    "url": "https://github.com/adasarpan404/limitly/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js",
      "require": "./dist/middleware/express.js"
    },
    "./fastify": {
      "types": "./dist/middleware/fastify.d.ts",
      "import": "./dist/middleware/fastify.js",
      "require": "./dist/middleware/fastify.js"
    },
    "./nest": {
      "types": "./dist/middleware/nest.d.ts",
      "import": "./dist/middleware/nest.js",
      "require": "./dist/middleware/nest.js"
    },
    "./hono": {
      "types": "./dist/middleware/hono.d.ts",
      "import": "./dist/middleware/hono.js",
      "require": "./dist/middleware/hono.js"
    },
    "./koa": {
      "types": "./dist/middleware/koa.d.ts",
      "import": "./dist/middleware/koa.js",
      "require": "./dist/middleware/koa.js"
    },
    "./bun": {
      "types": "./dist/middleware/bun.d.ts",
      "import": "./dist/middleware/bun.js",
      "require": "./dist/middleware/bun.js"
    },
    "./otel": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js",
      "require": "./dist/observability/index.js"
    },
    "./prometheus": {
      "types": "./dist/prometheus.d.ts",
      "import": "./dist/prometheus.js",
      "require": "./dist/prometheus.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/scripts && cp -r src/scripts dist/scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "prepublishOnly": "npm test",
    "pack:check": "npm pack --dry-run",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "keywords": [
    "limitly",
    "rate-limit",
    "rate-limiting",
    "redis",
    "express",
    "fastify",
    "hono",
    "koa",
    "bun",
    "nestjs",
    "nest",
    "sliding-window",
    "token-bucket",
    "distributed",
    "middleware",
    "ioredis",
    "valkey",
    "dragonfly",
    "dragonflydb",
    "memcached",
    "opentelemetry",
    "otel",
    "observability",
    "tracing",
    "metrics",
    "prometheus"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "@nestjs/core": ">=9.0.0",
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "ioredis": ">=5.0.0",
    "koa": ">=2.14.0",
    "memcached": ">=2.2.0",
    "@opentelemetry/api": ">=1.4.0",
    "prom-client": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "memcached": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "prom-client": "^15.1.3",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/koa": "^2.15.0",
    "@types/memcached": "^2.2.10",
    "@types/node": "^20.14.0",
    "express": "^4.19.2",
    "fastify": "^4.28.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.1",
    "koa": "^2.15.0",
    "memcached": "^2.2.2",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
